def integral_of_power(x_power):
    """
    Returns the indefinite integral of x^n.
    Input:
        x_power (int or float): the exponent n in x^n
    Returns:
        str: integral as a string including + C
    """
    if not isinstance(x_power, (int, float)):
        return None
    new_power = x_power + 1
    return f"x^{new_power}/{new_power} + C"

# Example usage
if __name__ == "__main__":
    print(integral_of_power(3))  # Output: x^4/4 + C
